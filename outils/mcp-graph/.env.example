# Variables d'environnement attendues par le serveur MCP Graph.
# À renseigner par le GARDIEN à l'exécution (jamais commitées). Copier en `.env` et remplir.
# AUCUNE valeur réelle ici — ce fichier ne documente que les NOMS attendus.

# Tenant Entra ID (annuaire) de la firme.
GRAPH_TENANT_ID=

# App registration (moindre privilège, Sites.Selected) — identifiant client (application).
GRAPH_CLIENT_ID=

# Secret client de l'app registration. Injecté à l'exécution. NE JAMAIS COMMITTER.
GRAPH_CLIENT_SECRET=

# Identifiant Graph du site SharePoint AlliaConsuling
# (format : contoso.sharepoint.com,<guid-site>,<guid-web>).
GRAPH_SITE_ID=

# Identifiant de la liste « Zone-de-proposition » — SEULE cible d'écriture autorisée.
GRAPH_PROPOSITION_LIST_ID=
